# Anthropic API (desde Secret Manager en Cloud Run)
ANTHROPIC_API_KEY=sk-ant-api03-...

# LLM Model - Sonnet 4.6
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_MAX_TOKENS=4096
